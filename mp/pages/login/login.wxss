.login-page{min-height:100vh;display:flex;flex-direction:column;align-items:center;justify-content:center;padding:60rpx 40rpx;background:#f5f6f8}
.login-logo{font-size:48rpx;font-weight:800;color:#FF6B35;margin-bottom:12rpx}
.login-sub{font-size:26rpx;color:#999;margin-bottom:60rpx}
.form-input{width:100%;height:100rpx;padding:0 30rpx;background:#fff;border-radius:16rpx;font-size:36rpx;text-align:center;box-sizing:border-box;border:2rpx solid #eee;line-height:100rpx}
.form-input:focus{border-color:#FF6B35}
.login-btn{width:100%;height:96rpx;background:#FF6B35;color:#fff;border-radius:16rpx;font-size:34rpx;font-weight:700;margin-top:50rpx;display:flex;align-items:center;justify-content:center;border:none;line-height:96rpx}
.login-btn::after{border:none}
.admin-link{margin-top:60rpx;font-size:26rpx;color:#ccc;padding:20rpx}