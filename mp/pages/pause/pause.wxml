<view class="page-pause">
  <view class="card">
    <view class="card-title">璇剧▼鏆傚仠</view>
    <view class="card-tip">鏈堝崱姣忔湀鏈€澶?娆°€傛鍗″彲鏆傚仠1娆°€傛殏鍋滄湡闂翠笉娑堣€椼€?/view>
    
    <block wx:if="{{courses.length===0}}">
      <view class="empty-state">
        <view class="empty-icon">馃摥</view>
        <view>娌℃湁鍙殏鍋滅殑璇剧▼</view>
      </view>
    </block>
    
    <block wx:else>
      <view class="course-list">
        <view class="course-item {{item.selClass}}" wx:for="{{courses}}" wx:key="id" bindtap="selectCourse" data-id="{{item.id}}" data-type="{{item.isMonthly?'monthly':'session'}}">
          <view>
            <view class="course-name">{{item.label}}</view>
            <view class="course-meta">{{item.limit}}</view>
          </view>
          <view class="check-circle {{item.selClass}}">{{item.selected ? "鉁? : "鈼?}}</view>
        </view>
      </view>
      
      <block wx:if="{{selectedCourseId}}">
        <view class="form-gap">
          <view class="form-item">
            <view class="form-label">鏆傚仠鏃ユ湡</view>
            <picker mode="date" value="{{pauseDate}}" bindchange="onDateChange">
              <view class="form-value">{{pauseDate}} 鈻?/view>
            </picker>
          </view>
          <view class="form-item">
            <view class="form-label">鍘熷洜(鍙€?</view>
            <input class="form-input" placeholder="鏈変簨澶栧嚭" value="{{reason}}" bindinput="onReasonInput"/>
          </view>
          <button class="primary-btn" bindtap="doPause">纭鏆傚仠</button>
        </view>
      </block>
    </block>
  </view>
  
  <view class="card" wx:if="{{pauses.length>0}}">
    <view class="card-title">鏆傚仠璁板綍</view>
    <view class="list-item" wx:for="{{pauses}}" wx:key="id">
      <view class="item-row">
        <view>
          <text class="item-date">{{item.pauseDate}}</text>
          <text class="item-type">{{item.label}}</text>
        </view>
        <view class="tag tag-{{item.statusClass}}">{{item.statusLabel}}</view>
      </view>
      <view class="item-reason" wx:if="{{item.reason}}">鍘熷洜锛歿{item.reason}}</view>
    </view>
  </view>
</view>