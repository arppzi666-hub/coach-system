.container{padding:40rpx;min-height:100vh;background:#f5f6f8}.card{background:#fff;border-radius:16rpx;padding:30rpx;box-shadow:0 2rpx 8rpx rgba(0,0,0,.04)}.title{font-size:36rpx;font-weight:700;margin-bottom:12rpx}.tip{font-size:24rpx;color:#999;margin-bottom:20rpx}.box{width:100%;min-height:300rpx;background:#f5f6f8;border-radius:12rpx;padding:20rpx;font-size:24rpx;border:1rpx solid #eee;box-sizing:border-box}.btn{width:100%;background:#FF6B35;color:#fff;border-radius:12rpx;padding:22rpx;font-size:30rpx;font-weight:600;text-align:center;border:none;margin-top:20rpx}.msg{margin-top:20rpx;font-size:24rpx;color:#07c160;text-align:center}