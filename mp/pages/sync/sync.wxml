<view style="padding:40rpx">
  <view style="font-size:36rpx;font-weight:700;margin-bottom:8rpx">数据同步 · 教练后台</view>
  <view style="font-size:24rpx;color:#666;margin-bottom:24rpx">{{status}}</view>
  
  <button style="width:100%;background:#07c160;color:#fff;border-radius:12rpx;padding:28rpx;font-size:32rpx;font-weight:600;margin-bottom:16rpx" bindtap="doSync">
    🔄 一键同步到云数据库
  </button>

  <view style="text-align:center;color:#bbb;font-size:22rpx;margin:16rpx 0">———— 或手动粘贴 ————</view>

  <textarea style="width:100%;min-height:120rpx;background:#f5f5f5;border-radius:12rpx;padding:20rpx;font-size:22rpx;box-sizing:border-box" placeholder="备用：粘贴JSON数据..." value="{{text}}" bindinput="onInput"/>
  
  <button style="width:100%;background:#FF6B35;color:#fff;border-radius:12rpx;padding:22rpx;font-size:30rpx;margin-top:16rpx" bindtap="importLocal">存到本地</button>

  <view wx:if="{{msg}}" style="margin-top:24rpx;padding:20rpx;background:#e8ffe8;border-radius:12rpx;font-size:28rpx;color:#07c160;text-align:center">{{msg}}</view>

  <view style="margin-top:24rpx;padding:16rpx;background:#333;border-radius:8rpx;min-height:100rpx">
    <view style="font-size:20rpx;color:#0f0;white-space:pre-line;font-family:monospace">{{log}}</view>
  </view>
</view>