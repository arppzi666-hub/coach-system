.page-checkin{padding:20rpx;min-height:100vh;background:#f5f6f8}
.card{background:#fff;border-radius:16rpx;padding:28rpx;margin-bottom:20rpx;box-shadow:0 2rpx 12rpx rgba(0,0,0,.04)}
.card-title{font-size:32rpx;font-weight:700;margin-bottom:20rpx}
.empty-state{display:flex;flex-direction:column;align-items:center;padding:60rpx 0;color:#999}
.empty-icon{font-size:80rpx;margin-bottom:16rpx}
.text-sm{font-size:24rpx;color:#999;margin-top:8rpx}
.course-item{display:flex;justify-content:space-between;align-items:center;padding:20rpx;border:2rpx solid #eee;border-radius:12rpx;margin-bottom:12rpx}
.course-item.checked{border-color:#FF6B35;background:#fff5f0}
.course-name{font-size:28rpx;font-weight:600}
.course-meta{font-size:24rpx;color:#999;margin-top:4rpx}
.check-circle{width:44rpx;height:44rpx;border:2rpx solid #ddd;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:28rpx;color:#ccc;flex-shrink:0}
.check-circle.checked{border-color:#FF6B35;color:#FF6B35;background:#fff5f0}
.btn-do{width:100%;background:#FF6B35;color:#fff;border:none;border-radius:12rpx;padding:24rpx;font-size:30rpx;font-weight:600;margin-top:16rpx}
.ci-item{padding:16rpx 0;border-bottom:1rpx solid #f5f5f5}
.ci-item:last-child{border-bottom:none}
.ci-date{font-size:28rpx;font-weight:500;color:#333}
.ci-type{font-size:24rpx;color:#999;margin-top:4rpx}
.tag{display:inline-block;padding:4rpx 16rpx;border-radius:6rpx;font-size:22rpx;font-weight:500;margin-right:8rpx}
.tag-monthly{background:#fff0e8;color:#FF6B35}
.tag-session{background:#e8f4ff;color:#3b82f6}
.tag-active{background:#e8ffe8;color:#07c160}
.tag-paused{background:#fff8e8;color:#e6a817}
.tag-expired{background:#ffe8e8;color:#fa5151}