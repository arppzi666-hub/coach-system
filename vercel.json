{
  "functions": {
    "api/students.js": { "memory": 256, "maxDuration": 10 },
    "api/courses.js": { "memory": 256, "maxDuration": 10 },
    "api/checkins.js": { "memory": 256, "maxDuration": 10 },
    "api/pauses.js": { "memory": 256, "maxDuration": 10 },
    "api/index.js": { "memory": 256, "maxDuration": 10 }
  },
  "routes": [
    { "src": "/api/students(?:\/([^\/]+))?", "dest": "/api/students" },
    { "src": "/api/courses(?:\/([^\/]+))?", "dest": "/api/courses" },
    { "src": "/api/checkins(?:\/([^\/]+))?", "dest": "/api/checkins" },
    { "src": "/api/pauses(?:\/([^\/]+))?", "dest": "/api/pauses" },
    { "src": "/(.*)", "dest": "/api/index" }
  ]
}